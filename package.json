{
  "name": "opencourse",
  "version": "0.1.0",
  "description": "Offline Course Player for the Terminal — auto-scan, progress tracking, quizzes, and a ghost mascot.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opencourse": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "tui",
    "course",
    "player",
    "terminal",
    "offline",
    "education",
    "ink",
    "react"
  ],
  "author": {
    "name": "David A. Mamani C.",
    "email": "david.abdiel.oficial@gmail.com",
    "url": "https://github.com/david-mamani"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/david-mamani/opencourse.git"
  },
  "homepage": "https://github.com/david-mamani/opencourse#readme",
  "bugs": {
    "url": "https://github.com/david-mamani/opencourse/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
